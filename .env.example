# Copy to .env and fill in. Never commit .env.

# Image generation (generate_image.js, generate_scene_images.js)
GOOGLE_AI_STUDIO_API_KEY=

# Local app TTS (scripts/local-app.js) — set what you use
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_B=
# ELEVENLABS_MODEL=eleven_v3
# ELEVENLABS_LANGUAGE=en
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY=0.75
# ELEVENLABS_TTS_TIMEOUT_MS=180000
GEMINI_API_KEY=
OPENAI_API_KEY=
AIVIS_API_KEY=
XAI_API_KEY=
GROK_API_KEY=

# Optional overrides

# Copy to .env and fill in. Never commit .env.

# Image generation (generate_image.js, generate_scene_images.js)
GOOGLE_AI_STUDIO_API_KEY=

# Local app TTS (scripts/local-app.js) — set what you use
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_B=
# ELEVENLABS_MODEL=eleven_v3
# ELEVENLABS_LANGUAGE=en
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY=0.75
# ELEVENLABS_TTS_TIMEOUT_MS=180000
# ElevenLabs API 側のネイティブ速度調節（0.7〜1.2 推奨）。
# これを使う場合は TTS_SPEED=1.0 にして ffmpeg 後処理を切るのが推奨
# （ffmpeg atempo より自然・末尾リピート抑制効果あり）
# ELEVENLABS_API_SPEED=0.9
GEMINI_API_KEY=
OPENAI_API_KEY=
AIVIS_API_KEY=
XAI_API_KEY=
GROK_API_KEY=

# Optional overrides
# PORT=3847
# FFMPEG_PATH=
# GEMINI_TTS_VOICE=Kore
# OPENAI_TTS_VOICE=nova
